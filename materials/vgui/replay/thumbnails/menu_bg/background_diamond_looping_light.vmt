"UnlitGeneric"
{
	"$basetexture" "vgui/replay/thumbnails/menu_bg/background_diamond_looping_light"
	"$vertexcolor" 1
	"$no_fullbright" 1
	"$ignorez" 1
	"%keywords" "tf"
